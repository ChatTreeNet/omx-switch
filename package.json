{
  "name": "vibepulse",
  "version": "0.3.0-beta.1",
  "private": false,
  "description": "Real-time dashboard for monitoring and managing OpenCode sessions",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChatTreeNet/VibePulse"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    ".next",
    "bin",
    "public",
    "package.json",
    "next.config.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "node ./bin/dev-runtime.js",
    "dev:hub": "node ./bin/dev-runtime.js hub",
    "dev:node": "node ./bin/dev-runtime.js node",
    "build": "next build",
    "start": "next start -p 3456",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "build:lib": "tsup src/index.ts --format cjs,esm --dts --clean --outDir dist --external react,react-dom,next --tsconfig tsconfig.lib.json"
  },
  "bin": {
    "vibepulse": "./bin/vibepulse.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@opencode-ai/sdk": "1.14.48",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.90.21",
    "clsx": "^2.1.1",
    "comment-json": "^4.6.2",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.2",
    "esbuild-plugin-alias": "^0.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^26.1.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
